{
  "compilerOptions": {
    /* Language */
    "target": "ES2020",
    "module": "commonjs",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    // /* Module Resolution */
    // "moduleResolution": "node",
    // "esModuleInterop": true,
    // "resolveJsonModule": true,

    /* Strict Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Source Maps */
    "sourceMap": true,

    /* Node compatibility */
    "types": ["node"]
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
