{
  "compilerOptions": {
    /* Language */
    "target": "ES2020",
    "module": "commonjs",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    // /* Module Resolution */
    // "moduleResolution": "node",
    // "esModuleInterop": true,
    // "resolveJsonModule": true,

    /* Strict Type Checking */


    /* Source Maps */
    "sourceMap": true,

    /* Node compatibility */
    "types": ["node"],


    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
